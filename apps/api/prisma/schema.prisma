// prisma/schema.prisma
// CrochetCraft Pro — Complete Database Schema
// Database: PostgreSQL (Neon)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider  = "mongodb"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum DiscountType {
  PERCENTAGE
  FLAT
  FIRST_PURCHASE
  CATEGORY
}

enum RefundStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROCESSED
}

enum CustomOrderStatus {
  PENDING
  REVIEWED
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id               String   @id @default(cuid()) @map("_id")
  name             String
  email            String   @unique
  password         String?
  phone            String?
  role             Role     @default(CUSTOMER)
  avatar           String?
  googleId         String?
  emailVerified    Boolean  @default(false)
  isActive         Boolean  @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  addresses        Address[]
  orders           Order[]
  reviews          Review[]
  wishlistItems    WishlistItem[]
  cartItems        CartItem[]
  refunds          Refund[]
  customOrders     CustomOrder[]
  browsingHistory  BrowsingHistory[]
  newsletterSubs   NewsletterSubscriber[]
  passwordResets   PasswordReset[]
  refreshTokens    RefreshToken[]
  @@index([role])
  @@map("users")
}

model Address {
  id         String  @id @default(cuid()) @map("_id")
  userId     String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String  @default("India")
  isDefault  Boolean @default(false)
  createdAt  DateTime @default(now())

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([userId])
  @@map("addresses")
}

model RefreshToken {
  id        String   @id @default(cuid()) @map("_id")
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid()) @map("_id")
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("password_resets")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid()) @map("_id")
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  coupons     Coupon[]
  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id              String      @id @default(cuid()) @map("_id")
  title           String
  slug            String      @unique
  description     String
  shortDescription String?
  price           Float
  salePrice       Float?
  stock           Int         @default(0)
  sku             String      @unique
  images          String[]    // Cloudinary URLs array
  categoryId      String
  featured        Boolean     @default(false)
  bestSeller      Boolean     @default(false)
  isActive        Boolean     @default(true)
  stockStatus     StockStatus @default(IN_STOCK)
  lowStockThreshold Int       @default(5)
  weight          Float?      // grams
  dimensions      Json?       // { length, width, height }
  tags            String[]
  material        String?
  careInstructions String?
  rating          Float       @default(0)
  reviewsCount    Int         @default(0)
  totalSold       Int         @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category        Category    @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  cartItems       CartItem[]
  browsingHistory BrowsingHistory[]
  inventoryLogs   InventoryLog[]
  @@index([categoryId])
  @@index([featured])
  @@index([bestSeller])
  @@index([isActive])
  @@index([stockStatus])
  @@index([price])
  @@index([rating])
  @@map("products")
}

model InventoryLog {
  id         String   @id @default(cuid()) @map("_id")
  productId  String
  quantity   Int      // positive = restock, negative = sale/deduction
  reason     String   // "ORDER", "RESTOCK", "MANUAL_ADJUSTMENT", "RETURN"
  reference  String?  // order ID or other reference
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("inventory_logs")
}

// ─────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────

model WishlistItem {
  id         String   @id @default(cuid()) @map("_id")
  userId     String
  productId  String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  productId String
  quantity  Int      @default(1)
  savedForLater Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// COUPONS
// ─────────────────────────────────────────────

model Coupon {
  id             String       @id @default(cuid()) @map("_id")
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Float
  minimumOrder   Float        @default(0)
  maximumDiscount Float?      // Cap for percentage coupons
  expiryDate     DateTime
  usageLimit     Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  isFirstPurchase Boolean     @default(false)
  categoryId     String?      // For CATEGORY type coupons
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  category       Category?    @relation(fields: [categoryId], references: [id])
  orders         Order[]
  usages         CouponUsage[]
  @@index([isActive])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid()) @map("_id")
  couponId  String
  userId    String
  orderId   String?
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id])

  @@index([couponId, userId])
  @@map("coupon_usages")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid()) @map("_id")
  orderNumber     String        @unique
  userId          String
  addressId       String
  subtotal        Float
  discountAmount  Float         @default(0)
  shippingCharge  Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float
  couponId        String?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(RAZORPAY)
  orderStatus     OrderStatus   @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  trackingNumber  String?
  courierName     String?
  trackingUrl     String?
  giftWrapping    Boolean       @default(false)
  giftMessage     String?
  notes           String?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  address         Address       @relation(fields: [addressId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  refunds         Refund[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid()) @map("_id")
  orderId    String
  productId  String
  title      String   // snapshot at order time
  image      String   // snapshot at order time
  quantity   Int
  price      Float    // snapshot at order time
  totalPrice Float

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id          String      @id @default(cuid()) @map("_id")
  orderId     String
  status      OrderStatus
  note        String?
  updatedBy   String?     // admin user ID
  createdAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id               String   @id @default(cuid()) @map("_id")
  userId           String
  productId        String
  orderId          String?
  rating           Int      // 1–5
  title            String?
  review           String
  images           String[]
  isVerifiedPurchase Boolean @default(false)
  isApproved       Boolean  @default(false)
  helpfulCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([isApproved])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// REFUNDS
// ─────────────────────────────────────────────

model Refund {
  id              String       @id @default(cuid()) @map("_id")
  orderId         String
  userId          String
  reason          String
  description     String?
  images          String[]
  amount          Float
  status          RefundStatus @default(PENDING)
  adminNote       String?
  razorpayRefundId String?
  requestedAt     DateTime     @default(now())
  reviewedAt      DateTime?
  processedAt     DateTime?

  order           Order        @relation(fields: [orderId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("refunds")
}

// ─────────────────────────────────────────────
// CUSTOM ORDERS
// ─────────────────────────────────────────────

model CustomOrder {
  id               String            @id @default(cuid()) @map("_id")
  userId           String
  name             String
  email            String
  phone            String
  description      String
  referenceImages  String[]
  colorPreferences String?
  quantity         Int               @default(1)
  specialInstructions String?
  status           CustomOrderStatus @default(PENDING)
  quotedPrice      Float?
  adminNote        String?
  dueDate          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("custom_orders")
}

// ─────────────────────────────────────────────
// BROWSING HISTORY & RECOMMENDATIONS
// ─────────────────────────────────────────────

model BrowsingHistory {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  productId   String
  viewedAt    DateTime @default(now())
  viewCount   Int      @default(1)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([viewedAt])
  @@map("browsing_history")
}

// ─────────────────────────────────────────────
// NEWSLETTER
// ─────────────────────────────────────────────

model NewsletterSubscriber {
  id           String   @id @default(cuid()) @map("_id")
  email        String   @unique
  userId       String?
  isSubscribed Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@map("newsletter_subscribers")
}

// ─────────────────────────────────────────────
// ANALYTICS EVENTS
// ─────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid()) @map("_id")
  event     String   // "PAGE_VIEW", "PRODUCT_VIEW", "ADD_TO_CART", "PURCHASE"
  userId    String?
  sessionId String?
  productId String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([userId])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────
// ABANDONED CART RECOVERY
// ─────────────────────────────────────────────

model AbandonedCartEmail {
  id            String   @id @default(cuid()) @map("_id")
  userId        String
  emailSentAt   DateTime @default(now())
  cartSnapshot  Json

  @@index([userId])
  @@map("abandoned_cart_emails")
}

model EmailLog {
  id        String   @id @default(cuid()) @map("_id")
  to        String
  subject   String
  service   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@map("email_logs")
}
